{
  "mcpServers": {
    "batch-review": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "batch-review",
        "--mcp",
        "--root",
        ".",
        "--skip-build"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
